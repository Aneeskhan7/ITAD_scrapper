# Database
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/ITAD_scrapper"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT — generate two random 96-char hex strings:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET="REPLACE_WITH_GENERATED_HEX_STRING"
JWT_REFRESH_SECRET="REPLACE_WITH_DIFFERENT_GENERATED_HEX_STRING"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# Ollama (local AI classifier)
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2"

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# Admin seed account (set before running database/002_seed.sql)
ADMIN_EMAIL="scrapperadmin@gmail.com"
ADMIN_PASSWORD="admin123"
